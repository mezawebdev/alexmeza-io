---
import data from "../data/projects.json";

interface ProjectLink {
  label: string;
  url: string;
}
interface ProjectImage {
  src: string;
  alt: string;
  caption?: string;
}
interface Project {
  id: string;
  title: string;
  client: string;
  role: string;
  year: string;
  yearStart: number;
  yearEnd: number | null;
  stack: string[];
  status: "live" | "archived" | "shelved";
  featured: boolean;
  summary: string;
  narrative: string[];
  award?: string;
  link?: ProjectLink;
  images: ProjectImage[];
  note?: string;
}

const projects = data.projects as Project[];

const sortKey = (p: Project): number =>
  p.yearEnd === null ? Number.MAX_SAFE_INTEGER : p.yearStart;

const featured = projects
  .filter((p) => p.featured)
  .sort((a, b) => sortKey(b) - sortKey(a));

const holding = projects
  .filter((p) => !p.featured)
  .sort((a, b) => sortKey(b) - sortKey(a));

const SHOW_HOLDING = false; // Clean hook — flip on when copy is ready.
---

<section class="selected-work" aria-labelledby="selected-work-heading">
  <p class="kicker" id="selected-work-heading">
    <span class="kicker__rule" aria-hidden="true"></span>
    <span>selected works</span>
  </p>

  <ol class="work-index" role="list">
    {
      featured.map((p, i) => (
        <li class={`row${i >= 3 ? " row--extra" : ""}`}>
          <button
            type="button"
            class="row-trigger"
            id={`row-${p.id}`}
            aria-expanded="false"
            aria-controls={`panel-${p.id}`}
          >
            <span class="row-main">
              <span class="row-title">{p.title}</span>
              <span class="row-summary">{p.summary}</span>
            </span>
            <span class="row-meta">
              <span class="meta-text">
                {p.client.toLowerCase()} · {p.year}
              </span>
              <span class="toggle" aria-hidden="true">
                +
              </span>
            </span>
          </button>

          <div
            id={`panel-${p.id}`}
            class="panel"
            role="region"
            aria-labelledby={`row-${p.id}`}
          >
            <div class="panel-inner">
              <div class="panel-content">
                {p.narrative.map((para) => (
                  <p class="narrative">{para}</p>
                ))}

                <p class="trail">
                  {[p.role, p.year, ...p.stack].join(" · ").toLowerCase()}
                </p>

                {p.images.length > 0 && (
                  <div class="shots" data-count={p.images.length}>
                    {p.images.map((img) => (
                      <figure class="shot">
                        <img
                          src={img.src}
                          alt={img.alt}
                          loading="lazy"
                          decoding="async"
                        />
                        {img.caption && <figcaption>{img.caption}</figcaption>}
                      </figure>
                    ))}
                  </div>
                )}

                {p.link?.url && (
                  <p class="link">
                    <a href={p.link.url} target="_blank" rel="noopener noreferrer">
                      {p.link.label}
                      <span class="arrow" aria-hidden="true">↗</span>
                    </a>
                  </p>
                )}
              </div>
            </div>
          </div>
        </li>
      ))
    }
    {featured.length > 3 && (
      <li class="row-more">
        <button type="button" class="row-more__btn" aria-expanded="false">
          see more <span aria-hidden="true">+</span>
        </button>
      </li>
    )}
  </ol>

  {
    SHOW_HOLDING && holding.length > 0 && (
      <p class="also">
        <span class="also-label">also worked on</span>
        <span class="also-list">
          {holding.map((p, i) => (
            <>
              {i > 0 && <span class="dot"> · </span>}
              <span>{p.title.toLowerCase()}</span>
            </>
          ))}
        </span>
      </p>
    )
  }
</section>

<style>
  .selected-work {
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    padding: 24px 32px 140px;
    position: relative;
    z-index: 3;
  }

  .kicker {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    padding: 16px 0 12px;
    margin-bottom: 0;
  }
  .kicker__rule {
    width: 24px;
    height: 1px;
    background: var(--text-muted);
    opacity: 0.45;
    flex-shrink: 0;
  }

  .work-index {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .row {
    border-top: 1px solid var(--border);
  }
  .row:first-child {
    border-top: 0;
  }
  .row:last-child {
    border-bottom: 1px solid var(--border);
  }

  .row-trigger {
    width: 100%;
    background: none;
    border: 0;
    padding: 28px 0;
    text-align: left;
    color: inherit;
    font: inherit;
    cursor: pointer;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 24px;
    font-family: inherit;
  }
  .row-trigger:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 8px;
    border-radius: 2px;
  }

  .row-main {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .row-title {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 32px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--text);
    opacity: 0.82;
    transition: opacity 0.25s ease;
  }
  .row:hover .row-title,
  .row-trigger:focus-visible .row-title,
  .row.is-open .row-title {
    opacity: 1;
  }

  .row-summary {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .row-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 12px;
    white-space: nowrap;
  }

  .meta-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .toggle {
    font-family: "JetBrains Mono", monospace;
    font-size: 18px;
    color: var(--text-muted);
    width: 14px;
    text-align: center;
    line-height: 1;
    user-select: none;
    transition: color 0.25s ease;
  }
  .row:hover .toggle,
  .row.is-open .toggle {
    color: var(--accent);
  }

  /* Accordion panel via grid-template-rows trick */
  .panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .row.is-open .panel {
    grid-template-rows: 1fr;
  }
  .panel-inner {
    overflow: hidden;
    min-height: 0;
  }

  .panel-content {
    padding: 12px 0 36px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .narrative {
    font-size: 16px;
    color: var(--text);
    line-height: 1.7;
    max-width: 560px;
  }

  .trail {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: -4px;
    word-spacing: 2px;
  }

  .shots {
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
    margin-top: 4px;
  }
  .shots[data-count="2"] {
    grid-template-columns: 1fr 1fr;
  }

  .shot {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .shot img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .shot figcaption {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .link {
    margin-top: 2px;
  }
  .link a {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.03em;
    border-bottom: 1px solid rgba(122, 173, 255, 0.25);
    padding-bottom: 1px;
    transition: border-color 0.2s ease;
  }
  .link a:hover {
    border-bottom-color: var(--accent);
  }
  .link .arrow {
    display: inline-block;
    margin-left: 4px;
    transform: translateY(-1px);
  }

  .also {
    margin-top: 56px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    line-height: 1.8;
    opacity: 0.7;
  }
  .also-label {
    margin-right: 14px;
    opacity: 0.7;
  }
  .also .dot {
    opacity: 0.5;
  }

  /* See more — mobile only */
  .row-more {
    display: none;
    border-top: 1px solid var(--border);
  }
  .row-more__btn {
    width: 100%;
    background: none;
    border: 0;
    padding: 22px 0;
    text-align: left;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .row-more__btn:hover,
  .row-more__btn:focus-visible {
    color: var(--accent);
  }
  .row-more__btn span {
    display: inline-block;
    margin-left: 8px;
  }

  @media (max-width: 640px) {
    .work-index:not(.is-expanded) .row--extra {
      display: none;
    }
    .work-index:not(.is-expanded) .row-more {
      display: list-item;
    }
  }

  @media (max-width: 640px) {
    .selected-work {
      padding: 16px 24px 100px;
    }
    .row-trigger {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 22px 0;
    }
    .row-title {
      font-size: 26px;
    }
    .row-meta {
      padding-top: 2px;
      justify-content: space-between;
    }
    .shots[data-count="2"] {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .panel,
    .row-title,
    .toggle,
    .link a {
      transition: none;
    }
  }
</style>

<script>
  type Row = {
    el: HTMLElement;
    btn: HTMLButtonElement;
    panel: HTMLElement;
    toggle: HTMLElement | null;
  };

  const rows: Row[] = Array.from(
    document.querySelectorAll<HTMLElement>(".selected-work .row:not(.row-more)")
  ).map((el) => ({
    el,
    btn: el.querySelector<HTMLButtonElement>(".row-trigger")!,
    panel: el.querySelector<HTMLElement>(".panel")!,
    toggle: el.querySelector<HTMLElement>(".toggle"),
  }));

  const setOpen = (r: Row, open: boolean): void => {
    r.el.classList.toggle("is-open", open);
    r.btn.setAttribute("aria-expanded", String(open));
    if (open) {
      r.panel.removeAttribute("inert");
    } else {
      r.panel.setAttribute("inert", "");
    }
    if (r.toggle) r.toggle.textContent = open ? "−" : "+";
  };

  rows.forEach((r) => setOpen(r, false));

  rows.forEach((r) => {
    r.btn.addEventListener("click", () => {
      const wasOpen = r.el.classList.contains("is-open");
      rows.forEach((other) => {
        if (other !== r) setOpen(other, false);
      });
      setOpen(r, !wasOpen);
    });
  });

  // "see more" — reveal hidden rows on mobile
  const moreBtn = document.querySelector<HTMLButtonElement>(".row-more__btn");
  const workIndex = document.querySelector<HTMLElement>(".work-index");
  if (moreBtn && workIndex) {
    moreBtn.addEventListener("click", () => {
      workIndex.classList.add("is-expanded");
      moreBtn.setAttribute("aria-expanded", "true");
    });
  }
</script>
