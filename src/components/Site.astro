---
import { Image } from "astro:assets";
import avatar from "../assets/avatar.jpg";
// TEMP (pre-launch): the selected-works section is hidden until its content
// is ready. To restore, uncomment this import + the commented blocks below,
// and revert src/pages/work.astro.
// import SelectedWork from "./SelectedWork.astro";
---

<section
  class="screen screen-hero"
  id="hero"
  data-section-path="/"
  aria-label="Intro"
>
  <div class="hero">
    <div class="hero-identity">
      <Image
        src={avatar}
        alt="Alex Meza"
        class="avatar"
        width={112}
        height={112}
        format="webp"
        loading="eager"
      />
      <h1 class="hero-name">Alex Meza</h1>
    </div>
    <p class="hero-intro">
      Software crafter. I like clean architecture, thoughtful UI, and building
      things that feel right. Currently exploring: agentic engineering, harness
      design, AI-augmented workflows.
    </p>
    <div class="hero-links">
      <a href="https://github.com/mezawebdev">github</a>
      <span class="sep">/</span>
      <a href="https://www.linkedin.com/in/mezawebdev/">linkedin</a>
    </div>
  </div>

  {/* TEMP (pre-launch): scroll cue hidden — nothing to scroll to yet.
  <a
    href="#work"
    class="scroll-cue"
    aria-label="Scroll to selected works"
    data-scroll-to="work"
  >
    {[0, 1, 2, 3, 4].map((i) => (
      <svg
        class="scroll-cue__chevron"
        style={`--i: ${i}`}
        viewBox="0 0 24 14"
        aria-hidden="true"
      >
        <path
          d="M2 2 L12 12 L22 2"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    ))}
  </a>
  */}
</section>

{/* TEMP (pre-launch): selected-works section hidden until content is ready.
<section
  class="screen screen-work"
  id="work"
  data-section-path="/work"
  aria-label="Selected works"
>
  <SelectedWork />
</section>
*/}

<style>
  html {
    scroll-behavior: smooth;
  }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
  }

  /* Hero screen — centered viewport */
  .screen-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero {
    width: 100%;
    max-width: 580px;
    padding: 32px;
    margin: 0 auto;
    position: relative;
    z-index: 3;
  }

  .hero-identity {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
  }

  .avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }

  .hero-name {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 56px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text);
    margin: 0;
    padding: 0;
  }

  .hero-intro {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 520px;
  }

  .hero-links {
    display: flex;
    gap: 24px;
    margin-top: 40px;
  }
  .hero-links a {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .hero-links a:hover {
    color: var(--accent);
  }
  .hero-links .sep {
    color: var(--border);
    user-select: none;
  }

  /* Scroll cue — chevron tracer (afterimage trail rising and fading) */
  .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 36px;
    transform: translateX(-50%);
    width: 32px;
    height: 44px;
    color: var(--text-muted);
    text-decoration: none;
    line-height: 0;
    z-index: 3;
    transition: color 0.2s ease;
  }
  .scroll-cue:hover {
    color: var(--accent);
  }
  .scroll-cue__chevron {
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 24px;
    height: 14px;
    transform: translateX(-50%);
    opacity: 0;
    animation: scroll-cue-trail 2.6s ease-out infinite;
    animation-delay: calc(var(--i) * 0.52s);
    overflow: visible;
  }

  @keyframes scroll-cue-trail {
    0% {
      transform: translate(-50%, 0) scale(1);
      opacity: 0;
    }
    20% {
      opacity: 0.45;
    }
    100% {
      transform: translate(-50%, -34px) scale(0.7);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { height: 14px; }
    .scroll-cue__chevron { animation: none; opacity: 0.6; transform: translateX(-50%); }
    .scroll-cue__chevron:not(:first-child) { display: none; }
  }

  /* Work screen — at least one viewport tall so each "page" reads as full */
  .screen-work {
    min-height: 100vh;
    position: relative;
  }

  @media (max-width: 640px) {
    .screen-hero {
      padding-bottom: 56px;
    }
    .hero {
      padding: 24px;
    }
    .hero-identity {
      gap: 14px;
      margin-bottom: 28px;
    }
    .avatar {
      width: 44px;
      height: 44px;
    }
    .hero-name {
      font-size: 40px;
    }
    .hero-intro {
      font-size: 16px;
    }
    .hero-links {
      margin-top: 32px;
    }
    .scroll-cue {
      bottom: 24px;
    }
  }
</style>

