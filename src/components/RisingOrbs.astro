---
// Rising orbs that float up from the bottom of the page and fade out
---

<div class="rising-orbs" aria-hidden="true">
  <div class="rising-orb ro-1"></div>
  <div class="rising-orb ro-2"></div>
  <div class="rising-orb ro-3"></div>
  <div class="rising-orb ro-4"></div>
  <div class="rising-orb ro-5"></div>
  <div class="rising-orb ro-6"></div>
  <div class="rising-orb ro-7"></div>
  <div class="rising-orb ro-8"></div>
  <div class="rising-orb ro-9"></div>
  <div class="rising-orb ro-10"></div>
  <div class="rising-orb ro-11"></div>
  <div class="rising-orb ro-12"></div>
</div>

<style>
  .rising-orbs {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 300px;
    pointer-events: none;
    z-index: 2;
    overflow: hidden;
  }

  .rising-orb {
    position: absolute;
    bottom: -20px;
    border-radius: 50%;
    filter: blur(4px);
    opacity: 0;
    animation: rise linear infinite, pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { filter: blur(4px) brightness(1); }
    50% { filter: blur(6px) brightness(1.6); }
  }


  .ro-1  { width: 6px;  height: 6px;  background: rgba(122, 173, 255, 0.6);  left: 8%;   animation-duration: 12s; animation-delay: 0s; }
  .ro-2  { width: 4px;  height: 4px;  background: rgba(167, 139, 250, 0.5);  left: 18%;  animation-duration: 15s; animation-delay: 2s; }
  .ro-3  { width: 8px;  height: 8px;  background: rgba(122, 173, 255, 0.4);  left: 30%;  animation-duration: 18s; animation-delay: 4s; }
  .ro-4  { width: 3px;  height: 3px;  background: rgba(167, 139, 250, 0.7);  left: 42%;  animation-duration: 10s; animation-delay: 1s; }
  .ro-5  { width: 5px;  height: 5px;  background: rgba(122, 173, 255, 0.5);  left: 55%;  animation-duration: 14s; animation-delay: 6s; }
  .ro-6  { width: 7px;  height: 7px;  background: rgba(167, 139, 250, 0.35); left: 65%;  animation-duration: 20s; animation-delay: 3s; }
  .ro-7  { width: 4px;  height: 4px;  background: rgba(122, 173, 255, 0.6);  left: 75%;  animation-duration: 11s; animation-delay: 8s; }
  .ro-8  { width: 6px;  height: 6px;  background: rgba(167, 139, 250, 0.45); left: 85%;  animation-duration: 16s; animation-delay: 5s; }
  .ro-9  { width: 3px;  height: 3px;  background: rgba(122, 173, 255, 0.55); left: 22%;  animation-duration: 13s; animation-delay: 7s; }
  .ro-10 { width: 5px;  height: 5px;  background: rgba(167, 139, 250, 0.4);  left: 48%;  animation-duration: 17s; animation-delay: 9s; }
  .ro-11 { width: 4px;  height: 4px;  background: rgba(122, 173, 255, 0.5);  left: 92%;  animation-duration: 14s; animation-delay: 11s; }
  .ro-12 { width: 7px;  height: 7px;  background: rgba(167, 139, 250, 0.3);  left: 37%;  animation-duration: 19s; animation-delay: 3.5s; }

  @keyframes rise {
    0% {
      transform: translateY(0) translateX(0);
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    25% {
      transform: translateY(-80px) translateX(15px);
    }
    50% {
      transform: translateY(-160px) translateX(-10px);
      opacity: 0.7;
    }
    75% {
      transform: translateY(-240px) translateX(20px);
      opacity: 0.3;
    }
    100% {
      transform: translateY(-300px) translateX(-5px);
      opacity: 0;
    }
  }
</style>
